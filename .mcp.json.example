{
  "//": "Copy to .mcp.json and adjust. .mcp.json is gitignored — keep secrets out of source.",
  "//sources": "Each source named in cleo.toml [[sources]] maps to one server here.",
  "//env": "${VAR} is interpolated from your environment (which cleo loads from .env).",
  "mcpServers": {
    "rss": {
      "command": "python",
      "args": ["-m", "servers.rss.server"],
      "//": "Ships in this repo (servers/rss). The keystone source — no keys, browser-grade UA so the Verge/Ars don't 403."
    },
    "weather": {
      "command": "python",
      "args": ["-m", "servers.weather.server"],
      "//": "Ships in this repo (servers/weather). Open-Meteo — no key; set lat/lon in cleo.toml."
    },
    "gmail": {
      "command": "python",
      "args": ["-m", "servers.gmail.server"],
      "env": { "GMAIL_OAUTH_TOKEN": "${GMAIL_OAUTH_TOKEN}" },
      "//": "Scaffold. Newsletters paywalled on the web (Stratechery, Money Stuff) arrive here instead."
    },
    "x": {
      "command": "python",
      "args": ["-m", "servers.x.server"],
      "env": { "X_BEARER_TOKEN": "${X_BEARER_TOKEN}" },
      "//": "Scaffold. Your curated X/Twitter list."
    },
    "calendar": {
      "command": "python",
      "args": ["-m", "servers.calendar.server"],
      "env": { "GOOGLE_CALENDAR_TOKEN": "${GOOGLE_CALENDAR_TOKEN}" },
      "//": "Scaffold. Your week ahead, for the Desk."
    }
  }
}
