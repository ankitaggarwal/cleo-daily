# ─────────────────────────────────────────────────────────────────────────────
#  Cleo Daily — secrets.  Copy to `.env` and fill in only what you switch on.
#  `.env` is gitignored. Never commit real keys.
#
#  The rule:  a feature runs only if its [features] flag in cleo.toml is ON
#             *and* the key(s) below are present. Leave a key blank to keep that
#             feature off. Run `cleo doctor` to see what's live.
# ─────────────────────────────────────────────────────────────────────────────

# ── The Editor ───────────────────────────────────────────────────────────────
# Only needed to run the Editor LOCALLY (`cleo edit`, outside a Claude routine).
# In a scheduled Claude routine the routine *is* the Editor — no key needed here.
ANTHROPIC_API_KEY=

# ── Default roster: RSS + weather ────────────────────────────────────────────
# The wide RSS net and the open-meteo weather line need NO keys. Nothing to do.

# ── images   → [features] images = true ──────────────────────────────────────
# Optional single-ink line-art illustrations.
GEMINI_API_KEY=

# ── inbox    → [features] inbox = true ───────────────────────────────────────
# Your Gmail newsletters (Money Stuff, paywalled subs that arrive by email).
GMAIL_OAUTH_TOKEN=

# ── signals  → [features] signals = true ─────────────────────────────────────
# An X / Twitter list you curate.
X_BEARER_TOKEN=

# ── calendar → [features] calendar = true ────────────────────────────────────
# Your week ahead, for the Desk.
GOOGLE_CALENDAR_TOKEN=

# ── email    → [features] email = true ───────────────────────────────────────
# Email the finished PDF to a list.
RESEND_API_KEY=
CLEO_SUBSCRIBERS=          # comma-separated addresses

# ── web      → [features] web = true ─────────────────────────────────────────
# Where to push the published edition (a deploy hook, bucket, or repo URL).
CLEO_WEB_TARGET=
